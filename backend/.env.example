# Server Port
PORT=10000

# Firebase Admin SDK Service Account Credentials
# Get these from your Firebase project settings > Service accounts > Generate new private key
# It's recommended to base64 encode the private key and decode it in your config
# For simplicity here, we'll just use the raw value, but be careful with newlines.
# Best practice for production: use environment variable management from your hosting provider (e.g., Render).
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"